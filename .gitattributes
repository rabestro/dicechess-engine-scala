# Default behavior: enforce LF line endings for all text files automatically
* text=auto eol=lf

# Scala source files
*.scala       text eol=lf
*.sbt         text eol=lf

# Frontend / Astro / Web configuration files
*.html        text eol=lf
*.css         text eol=lf
*.js          text eol=lf
*.cjs         text eol=lf
*.mjs         text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.astro       text eol=lf

# Documentation and configuration files
*.md          text eol=lf
*.mdx         text eol=lf
*.txt         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.conf        text eol=lf
.editorconfig text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Explicit binary declarations to prevent line ending corruption
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.svg         text eol=lf

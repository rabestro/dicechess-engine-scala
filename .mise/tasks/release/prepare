#!/usr/bin/env bash
# mise description="📌 Prepare release (bump version, commit, create tag)"

set -euo pipefail

# Help text
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  mise run release:help
  exit 0
fi

# Validate argument
if [[ -z "${1:-}" ]]; then
  echo "❌ Error: bump type not specified"
  echo ""
  mise run release:help
  exit 1
fi

bump_type="$1"
if [[ ! "$bump_type" =~ ^(patch|minor|major)$ ]]; then
  echo "❌ Error: invalid bump type '$bump_type'"
  echo "   Valid options: patch, minor, major"
  exit 1
fi

# Get current version from build.sbt (without -SNAPSHOT)
current_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")
current_version="${current_tag#v}"

# Parse version components
major=$(echo "$current_version" | cut -d. -f1)
minor=$(echo "$current_version" | cut -d. -f2)
patch=$(echo "$current_version" | cut -d. -f3)

# Calculate new version
case "$bump_type" in
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  patch)
    patch=$((patch + 1))
    ;;
esac

new_version="${major}.${minor}.${patch}"
new_tag="v${new_version}"

# Show summary
echo ""
echo "=== RELEASE SUMMARY ==="
echo ""
echo "  Current version: $current_version ($current_tag)"
echo "  Bump type:      $bump_type"
echo "  New version:    $new_version ($new_tag)"
echo ""
echo "Changes to be made:"
echo "  📄 build.sbt:    0.1.0-SNAPSHOT → $new_version"
echo "  📦 package.json: 0.1.0 → $new_version"
echo "  🏷️  Git tag:     $new_tag"
echo ""

# Ask for confirmation
read -p "Do you want to proceed? (yes/no) " -r confirm
if [[ ! "$confirm" =~ ^[Yy][Ee][Ss]$ ]]; then
  echo "❌ Release cancelled"
  exit 1
fi

echo ""
echo "⏳ Preparing release..."

# Update build.sbt
sed -i.bak "s/version.*:= \"[^\"]*\"/version      := \"$new_version\"/" build.sbt
rm build.sbt.bak

# Update package.json
sed -i.bak "s/\"version\": \"[^\"]*\"/\"version\": \"$new_version\"/" package.json
rm package.json.bak

# Create commit
git add build.sbt package.json
git commit -m "chore(release): bump version to $new_version

- Update build.sbt: $new_version
- Update package.json: $new_version

Resolves: #XX (replace with your issue number in the PR)"

# Create tag
git tag "$new_tag" -m "Release $new_version"

echo ""
echo "✅ Release prepared successfully!"
echo ""
echo "=== NEXT STEPS ==="
echo ""
echo "1. Verify the changes:"
echo "   git log -1 --oneline"
echo "   git show --stat"
echo ""
echo "2. Review the tag:"
echo "   git tag -ln"
echo ""
echo "3. Push to GitHub:"
echo "   git push origin"
echo "   git push origin --tags"
echo ""
echo "4. Create a Pull Request linking to the issue"
echo ""
echo "5. After PR is merged, GitHub Actions will automatically"
echo "   publish the package to npm via the 'publish.yml' workflow"
echo ""

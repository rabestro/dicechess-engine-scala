#!/usr/bin/env bash
# mise description="📖 Show release pipeline documentation"

echo ""
echo "=== RELEASE PIPELINE - USAGE INSTRUCTIONS ==="
echo ""
echo "Prepare a new release with automatic version bumping:"
echo ""
echo "  mise run release:prepare [patch|minor|major]"
echo ""
echo "Examples:"
echo "  mise run release:prepare patch  # 0.1.0 -> 0.1.1"
echo "  mise run release:prepare minor  # 0.1.0 -> 0.2.0"
echo "  mise run release:prepare major  # 0.1.0 -> 1.0.0"
echo ""
echo "What the task does:"
echo "  1. Validates the bump type (patch/minor/major)"
echo "  2. Calculates the new version"
echo "  3. Shows the version change and asks for confirmation"
echo "  4. Updates version in build.sbt and package.json"
echo "  5. Creates a git commit with the changes"
echo "  6. Creates a git tag (v<version>)"
echo "  7. Provides instructions for pushing to GitHub"
echo ""
echo "Workflow:"
echo "  1. Make sure you are on a task branch (task/XXX-...)"
echo "  2. Run: mise run release:prepare [type]"
echo "  3. Confirm when prompted"
echo "  4. Review the changes: git log -1, git show"
echo "  5. Push: git push origin && git push origin --tags"
echo "  6. Create a PR linking to the issue"
echo ""
